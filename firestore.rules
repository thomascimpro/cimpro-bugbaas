rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validStatus(status) {
      return status in ['Nieuw', 'Bevestigd', 'In behandeling', 'Gefixt', 'Afgekeurd', 'Dubbel'];
    }

    function validSeverity(severity) {
      return severity in ['Laag', 'Normaal', 'Hoog', 'Kritiek'];
    }

    function validNotificationType(type) {
      return type in ['trade', 'new_bug', 'comment', 'bug_update', 'bugdex', 'duel'];
    }

    function orgId(data) {
      return data.keys().hasAny(['organizationId']) ? data.organizationId : 'public';
    }

    function orgName(data) {
      return data.keys().hasAny(['organizationName']) ? data.organizationName : 'Public';
    }

    function currentOrgId() {
      return signedIn()
        ? orgId(get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
        : 'public';
    }

    function currentOrgIds() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(['organizationIds'])
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationIds
        : [];
    }

    function userIsOrgMember(organizationId) {
      return signedIn()
        && organizationId is string
        && organizationId != 'public'
        && (
          currentOrgId() == organizationId
          || organizationId in currentOrgIds()
          || exists(/databases/$(database)/documents/organizations/$(organizationId)/members/$(request.auth.uid))
        );
    }

    function publicOrSameOrg(data) {
      return signedIn() && (orgId(data) == 'public' || userIsOrgMember(orgId(data)));
    }

    function currentUserEmail() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email
        : '';
    }

    function inviteTargetsCurrentUser(data) {
      return signedIn()
        && (
          data.invitedEmail == currentUserEmail()
          || (data.keys().hasAny(['invitedUserId']) && data.invitedUserId == request.auth.uid)
        );
    }

    function organizationAdmin(organizationId) {
      return signedIn()
        && organizationId is string
        && organizationId != 'public'
        && (
          get(/databases/$(database)/documents/organizations/$(organizationId)).data.createdBy == request.auth.uid
          || (
            exists(/databases/$(database)/documents/organizations/$(organizationId)/members/$(request.auth.uid))
            && get(/databases/$(database)/documents/organizations/$(organizationId)/members/$(request.auth.uid)).data.role in ['owner', 'admin']
          )
        );
    }

    function validInventoryData(bugId) {
      return request.resource.data.bugId == bugId
        && request.resource.data.count is int
      && request.resource.data.count >= 0
        && request.resource.data.firstUnlockedAt is string
        && request.resource.data.lastUnlockedAt is string
        && request.resource.data.rarity is string
        && request.resource.data.sources is list;
    }

    function acceptedTradeData() {
      return request.resource.data.lastTradeId is string
        && getAfter(/databases/$(database)/documents/trades/$(request.resource.data.lastTradeId)).data.status == 'Geaccepteerd'
        && getAfter(/databases/$(database)/documents/trades/$(request.resource.data.lastTradeId)).data.toUserId == request.auth.uid;
    }

    function tradeGain(userId, bugId) {
      let trade = getAfter(/databases/$(database)/documents/trades/$(request.resource.data.lastTradeId)).data;
      return (userId == trade.fromUserId && bugId == trade.requestBugId)
        || (userId == trade.toUserId && bugId == trade.offerBugId);
    }

    function tradeLoss(userId, bugId) {
      let trade = getAfter(/databases/$(database)/documents/trades/$(request.resource.data.lastTradeId)).data;
      return (userId == trade.fromUserId && bugId == trade.offerBugId)
        || (userId == trade.toUserId && bugId == trade.requestBugId);
    }

    function tradeInventoryCreate(userId, bugId) {
      return signedIn()
        && validInventoryData(bugId)
        && acceptedTradeData()
        && tradeGain(userId, bugId)
        && request.resource.data.count == 1;
    }

    function tradeInventoryUpdate(userId, bugId) {
      return signedIn()
        && validInventoryData(bugId)
        && acceptedTradeData()
        && (
          (tradeGain(userId, bugId) && request.resource.data.count == resource.data.count + 1)
          || (tradeLoss(userId, bugId) && resource.data.count >= 1 && request.resource.data.count == resource.data.count - 1)
        );
    }

    function validUpvotes(data) {
      return data.upvoteUserIds is list
        && data.upvoteCount is int
        && data.upvoteCount == data.upvoteUserIds.size();
    }

    function onlyUpvoteFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvoteUserIds', 'upvoteCount', 'updatedAt']);
    }

    function firstLegacyUpvote() {
      return !resource.data.keys().hasAll(['upvoteUserIds', 'upvoteCount'])
        && validUpvotes(request.resource.data)
        && request.resource.data.upvoteCount == 1
        && request.auth.uid in request.resource.data.upvoteUserIds;
    }

    function toggledOwnUpvote() {
      return validUpvotes(resource.data)
        && validUpvotes(request.resource.data)
        && (
          (!(request.auth.uid in resource.data.upvoteUserIds)
            && request.auth.uid in request.resource.data.upvoteUserIds
            && request.resource.data.upvoteUserIds.size() == resource.data.upvoteUserIds.size() + 1
            && request.resource.data.upvoteUserIds.hasAll(resource.data.upvoteUserIds))
          ||
          (request.auth.uid in resource.data.upvoteUserIds
            && !(request.auth.uid in request.resource.data.upvoteUserIds)
            && resource.data.upvoteUserIds.size() == request.resource.data.upvoteUserIds.size() + 1
            && resource.data.upvoteUserIds.hasAll(request.resource.data.upvoteUserIds))
        );
    }

    function validBugCreate() {
      return request.resource.data.reporterId == request.auth.uid
        && (
          !request.resource.data.keys().hasAny(['organizationId'])
          || (request.resource.data.organizationId == 'public' && request.resource.data.organizationName == 'Public')
        )
        && request.resource.data.status == 'Nieuw'
        && validSeverity(request.resource.data.severity)
        && request.resource.data.title is string
        && request.resource.data.project is string
        && request.resource.data.description is string
        && validUpvotes(request.resource.data)
        && request.resource.data.upvoteCount == 0;
    }

    function validOrganizationBugCreate() {
      return request.resource.data.reporterId == request.auth.uid
        && request.resource.data.organizationId is string
        && request.resource.data.organizationId != 'public'
        && userIsOrgMember(request.resource.data.organizationId)
        && request.resource.data.organizationName is string
        && request.resource.data.status == 'Nieuw'
        && validSeverity(request.resource.data.severity)
        && request.resource.data.title is string
        && request.resource.data.project is string
        && request.resource.data.description is string
        && validUpvotes(request.resource.data)
        && request.resource.data.upvoteCount == 0;
    }

    function validUserUpdate(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && (
          (request.resource.data.organizationId == resource.data.organizationId
            && request.resource.data.organizationName == resource.data.organizationName)
          || (!request.resource.data.keys().hasAny(['organizationId'])
            && !resource.data.keys().hasAny(['organizationId']))
          || (!resource.data.keys().hasAny(['organizationId'])
            && request.resource.data.organizationId == 'public'
            && request.resource.data.organizationName == 'Public')
        )
        && request.resource.data.totalPoints is int
        && request.resource.data.totalPoints >= 0
        && request.resource.data.bugCount is int
        && request.resource.data.bugCount >= 0
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'active',
          'activeBugSquad',
          'badges',
          'bugCount',
          'bugDexCount',
          'bugLampActiveUntil',
          'bugLampCount',
          'characterId',
          'commentPointCount',
          'displayName',
          'helpSeen',
          'lastActiveAt',
          'legendaryBugDexCount',
          'movementKmTotal',
          'movementRegisteredDay',
          'movementRegisteredDayKm',
          'movementRegisteredWeek',
          'movementRegisteredWeekKm',
          'mythicBugDexCount',
          'nameSet',
          'notificationPushToken',
          'organizationId',
          'organizationIds',
          'organizationName',
          'organizationNames',
          'splatCount',
          'title',
          'totalPoints',
          'tradedBugDexCount',
          'upgradedBugDexCount',
          'upvoteGivenPointCount',
          'upvoteReceivedPointCount'
        ])
        && (!request.resource.data.keys().hasAny(['lastActiveAt']) || request.resource.data.lastActiveAt is string)
        && (!request.resource.data.keys().hasAny(['notificationPushToken']) || request.resource.data.notificationPushToken is string)
        && (!request.resource.data.keys().hasAny(['active']) || request.resource.data.active == true);
    }

    function organizationCreateUserUpdate(userId) {
      let organization = getAfter(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)).data;
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['organizationId', 'organizationIds', 'organizationName', 'organizationNames'])
        && request.resource.data.organizationId is string
        && request.resource.data.organizationId != 'public'
        && request.resource.data.organizationName is string
        && request.resource.data.organizationId == organization.id
        && request.resource.data.organizationName == organization.name
        && request.resource.data.organizationIds is list
        && organization.id in request.resource.data.organizationIds
        && request.resource.data.organizationNames is map
        && request.resource.data.organizationNames[organization.id] == organization.name
        && organization.createdBy == request.auth.uid;
    }

    function organizationInviteUserUpdate(userId) {
      let invite = getAfter(/databases/$(database)/documents/organizationInvites/$(request.resource.data.organizationInviteId)).data;
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['organizationId', 'organizationIds', 'organizationInviteId', 'organizationName', 'organizationNames'])
        && request.resource.data.organizationInviteId is string
        && invite.status == 'accepted'
        && invite.acceptedById == request.auth.uid
        && (invite.invitedEmail == resource.data.email || (invite.keys().hasAny(['invitedUserId']) && invite.invitedUserId == request.auth.uid))
        && invite.organizationId in request.resource.data.organizationIds
        && request.resource.data.organizationNames is map
        && request.resource.data.organizationNames[invite.organizationId] == invite.organizationName;
    }

    function organizationRemoveMemberUpdate(userId) {
      return signedIn()
        && request.auth.uid != userId
        && organizationAdmin(resource.data.organizationId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['organizationId', 'organizationIds', 'organizationName', 'organizationNames']);
    }

    function validInviteCreate() {
      return signedIn()
        && organizationAdmin(request.resource.data.organizationId)
        && request.resource.data.keys().hasOnly([
          'createdAt',
          'id',
          'invitedById',
          'invitedByName',
          'invitedEmail',
          'invitedUserId',
          'invitedUserName',
          'organizationId',
          'organizationName',
          'status'
        ])
        && request.resource.data.id is string
        && request.resource.data.invitedById == request.auth.uid
        && request.resource.data.invitedByName is string
        && request.resource.data.invitedEmail is string
        && (!request.resource.data.keys().hasAny(['invitedUserId']) || request.resource.data.invitedUserId is string)
        && (!request.resource.data.keys().hasAny(['invitedUserName']) || request.resource.data.invitedUserName is string)
        && (request.resource.data.invitedEmail.size() > 0 || request.resource.data.keys().hasAny(['invitedUserId']))
        && request.resource.data.organizationName == get(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)).data.name
        && request.resource.data.status == 'open'
        && request.resource.data.createdAt is string;
    }

    function cancelInvite() {
      return signedIn()
        && resource.data.status == 'open'
        && organizationAdmin(resource.data.organizationId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cancelledAt', 'status'])
        && request.resource.data.status == 'cancelled'
        && request.resource.data.cancelledAt is string;
    }

    function acceptInvite() {
      return signedIn()
        && resource.data.status == 'open'
        && inviteTargetsCurrentUser(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acceptedAt', 'acceptedById', 'status'])
        && request.resource.data.status == 'accepted'
        && request.resource.data.acceptedById == request.auth.uid
        && request.resource.data.acceptedAt is string;
    }

    function declineInvite() {
      return signedIn()
        && resource.data.status == 'open'
        && inviteTargetsCurrentUser(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['declinedAt', 'declinedById', 'status'])
        && request.resource.data.status == 'declined'
        && request.resource.data.declinedById == request.auth.uid
        && request.resource.data.declinedAt is string;
    }

    function reporterBugUpdate() {
      return publicOrSameOrg(resource.data)
        && resource.data.reporterId == request.auth.uid
        && request.resource.data.reporterId == resource.data.reporterId
        && validStatus(request.resource.data.status)
        && validSeverity(request.resource.data.severity)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'points', 'updatedAt']);
    }

    function upvoteUpdate() {
      return publicOrSameOrg(resource.data)
        && onlyUpvoteFieldsChanged()
        && resource.data.reporterId != request.auth.uid
        && (firstLegacyUpvote() || toggledOwnUpvote());
    }

    function isDuelParticipant(data) {
      return data.fromUserId == request.auth.uid || data.toUserId == request.auth.uid;
    }

    function duelBugCount() {
      return 56;
    }

    function validDuelCreate(duelId) {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'bugIds',
          'createdAt',
          'durationMs',
          'fromUserId',
          'fromUserName',
          'id',
          'rewardClaimedBy',
          'resultSeenBy',
          'scores',
          'seed',
          'status',
          'toUserId',
          'toUserName',
          'updatedAt'
        ])
        && request.resource.data.id == duelId
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.fromUserName is string
        && request.resource.data.toUserName is string
        && request.resource.data.status == 'pending'
        && request.resource.data.seed is int
        && request.resource.data.bugIds is list
        && request.resource.data.bugIds.size() == duelBugCount()
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.durationMs is int
        && request.resource.data.durationMs == 30000
        && request.resource.data.scores is map
        && request.resource.data.scores.size() == 0
        && request.resource.data.rewardClaimedBy is list
        && request.resource.data.rewardClaimedBy.size() == 0
        && request.resource.data.resultSeenBy is list
        && request.resource.data.resultSeenBy.size() == 0;
    }

    function acceptOrDeclineDuel() {
      return signedIn()
        && resource.data.status == 'pending'
        && resource.data.toUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'startAt'])
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.updatedAt is string
        && (
          request.resource.data.status == 'declined'
          || (request.resource.data.keys().hasAny(['startAt']) && request.resource.data.startAt is string)
        );
    }

    function cancelOwnDuel() {
      return signedIn()
        && resource.data.status == 'pending'
        && resource.data.fromUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.status == 'cancelled'
        && request.resource.data.updatedAt is string;
    }

    function submitOwnDuelScore() {
      let otherUserId = resource.data.fromUserId == request.auth.uid ? resource.data.toUserId : resource.data.fromUserId;
      let ownScore = request.resource.data.scores[request.auth.uid];
      return signedIn()
        && isDuelParticipant(resource.data)
        && (
          resource.data.status in ['accepted', 'completed']
          || (resource.data.status == 'pending' && resource.data.fromUserId == request.auth.uid)
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['scores', 'status', 'winnerId', 'updatedAt'])
        && (
          request.resource.data.status in ['accepted', 'completed']
          || (resource.data.status == 'pending' && request.resource.data.status == 'pending')
        )
        && request.resource.data.updatedAt is string
        && request.resource.data.scores is map
        && request.resource.data.scores.keys().hasOnly([resource.data.fromUserId, resource.data.toUserId])
        && request.resource.data.scores.keys().hasAny([request.auth.uid])
        && (!resource.data.scores.keys().hasAny([otherUserId]) || request.resource.data.scores[otherUserId] == resource.data.scores[otherUserId])
        && ownScore.score is int
        && ownScore.score >= 0
        && ownScore.score <= 1200
        && ownScore.caughtBugIds is list
        && ownScore.caughtBugIds.size() <= duelBugCount()
        && ownScore.bonusScore is int
        && ownScore.bonusScore >= 0
        && ownScore.bonusScore <= 100
        && ownScore.submittedAt is string
        && (!request.resource.data.keys().hasAny(['winnerId']) || request.resource.data.winnerId is string);
    }

    function claimOwnDuelReward() {
      let previousSeen = resource.data.keys().hasAny(['resultSeenBy']) ? resource.data.resultSeenBy : [];
      return signedIn()
        && resource.data.status == 'completed'
        && isDuelParticipant(resource.data)
        && resource.data.winnerId is string
        && request.resource.data.updatedAt is string
        && resource.data.rewardClaimedBy is list
        && request.resource.data.rewardClaimedBy is list
        && !(request.auth.uid in resource.data.rewardClaimedBy)
        && request.auth.uid in request.resource.data.rewardClaimedBy
        && request.resource.data.rewardClaimedBy.size() == resource.data.rewardClaimedBy.size() + 1
        && request.resource.data.rewardClaimedBy.hasAll(resource.data.rewardClaimedBy)
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rewardClaimedBy', 'resultSeenBy', 'updatedAt'])
            && previousSeen is list
            && request.resource.data.resultSeenBy is list
            && !(request.auth.uid in previousSeen)
            && request.auth.uid in request.resource.data.resultSeenBy
            && request.resource.data.resultSeenBy.size() == previousSeen.size() + 1
            && request.resource.data.resultSeenBy.hasAll(previousSeen)
          )
          ||
          (
            resource.data.winnerId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rewardClaimedBy', 'updatedAt'])
          )
        );
    }

    function acknowledgeDuelResult() {
      let previousSeen = resource.data.keys().hasAny(['resultSeenBy']) ? resource.data.resultSeenBy : [];
      return signedIn()
        && resource.data.status == 'completed'
        && isDuelParticipant(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resultSeenBy', 'updatedAt'])
        && request.resource.data.updatedAt is string
        && previousSeen is list
        && request.resource.data.resultSeenBy is list
        && !(request.auth.uid in previousSeen)
        && request.auth.uid in request.resource.data.resultSeenBy
        && request.resource.data.resultSeenBy.size() == previousSeen.size() + 1
        && request.resource.data.resultSeenBy.hasAll(previousSeen);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && (
          !request.resource.data.keys().hasAny(['organizationId'])
          || (request.resource.data.organizationId == 'public' && request.resource.data.organizationName == 'Public')
        )
        && (!request.resource.data.keys().hasAny(['active']) || request.resource.data.active == true);
      allow update: if signedIn()
        && (validUserUpdate(userId) || organizationCreateUserUpdate(userId) || organizationInviteUserUpdate(userId) || organizationRemoveMemberUpdate(userId));
      allow delete: if signedIn() && resource.data.reporterId == request.auth.uid;

      match /bugdex/{bugId} {
        allow read: if signedIn();
        allow create: if (signedIn()
          && request.auth.uid == userId
          && validInventoryData(bugId))
          || tradeInventoryCreate(userId, bugId);
        allow update: if (signedIn()
          && request.auth.uid == userId
          && validInventoryData(bugId))
          || tradeInventoryUpdate(userId, bugId);
        allow delete: if false;
      }

      match /bugdexEvents/{eventId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.id == eventId
          && request.resource.data.source is string
          && request.resource.data.createdAt is string;
        allow update, delete: if false;
      }

      match /duelRewardEvents/{eventId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create: if signedIn()
          && request.auth.uid == userId
          && eventId.matches('duel-daily-[0-9]{4}-[0-9]{2}-[0-9]{2}-.+')
          && request.resource.data.keys().hasOnly([
            'createdAt',
            'day',
            'duelId',
            'opponentId',
            'result'
          ])
          && request.resource.data.createdAt is string
          && request.resource.data.day is string
          && request.resource.data.duelId is string
          && request.resource.data.opponentId is string
          && request.resource.data.result in ['win', 'loss'];
        allow update, delete: if false;
      }

      match /weeklyMissionClaims/{claimId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create, update: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.id == claimId
          && request.resource.data.claimedAt is string
          && request.resource.data.keys().hasOnly([
            'claimedAt',
            'id',
            'missionIds',
            'missionTitle',
            'rewardBugId',
            'rewardGrantedAt',
            'rewardRarity',
            'rewardSource',
            'rewardType',
            'rewardXp'
          ]);
        allow delete: if false;
      }

      match /settings/{settingId} {
        allow read: if signedIn()
          && request.auth.uid == userId
          && settingId == 'notifications';
        allow create, update: if signedIn()
          && request.auth.uid == userId
          && settingId == 'notifications'
          && request.resource.data.trade is bool
          && request.resource.data.new_bug is bool
          && request.resource.data.comment is bool
          && request.resource.data.bug_update is bool
          && request.resource.data.bugdex is bool
          && request.resource.data.duel is bool;
        allow delete: if false;
      }

      match /soloCampaign/{progressId} {
        allow read: if signedIn()
          && request.auth.uid == userId
          && progressId == 'progress';
        allow create, update: if signedIn()
          && request.auth.uid == userId
          && progressId == 'progress'
          && request.resource.data.keys().hasOnly([
            'lives',
            'updatedAt',
            'wave'
          ])
          && request.resource.data.lives is int
          && request.resource.data.lives >= 1
          && request.resource.data.lives <= 3
          && request.resource.data.updatedAt is string
          && request.resource.data.wave is int
          && request.resource.data.wave >= 1
          && request.resource.data.wave <= 20;
        allow delete: if false;
      }

      match /notifications/{notificationId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create: if signedIn()
          && request.resource.data.id == notificationId
          && validNotificationType(request.resource.data.type)
          && request.resource.data.title is string
          && request.resource.data.body is string
          && request.resource.data.actorId == request.auth.uid
          && request.resource.data.actorName is string
          && request.resource.data.createdAt is string
          && request.resource.data.read == false;
        allow update: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
          && request.resource.data.read is bool;
        allow delete: if false;
      }
    }

    match /bugs/{bugId} {
      allow read: if signedIn();
      allow create: if signedIn() && validBugCreate();
      allow update: if signedIn() && (reporterBugUpdate() || upvoteUpdate());
      allow delete: if signedIn() && resource.data.reporterId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.bugId == bugId
          && (
            !request.resource.data.keys().hasAny(['organizationId'])
            || (request.resource.data.organizationId == 'public' && request.resource.data.organizationName == 'Public')
          )
          && request.resource.data.authorName is string
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 500
          && request.resource.data.reaction is string
          && request.resource.data.createdAt is string;
        allow update: if false;
        allow delete: if signedIn()
          && get(/databases/$(database)/documents/bugs/$(bugId)).data.reporterId == request.auth.uid;
      }
    }

    match /organizationBugs/{bugId} {
      allow read: if publicOrSameOrg(resource.data);
      allow create: if signedIn() && validOrganizationBugCreate();
      allow update: if signedIn() && (reporterBugUpdate() || upvoteUpdate());
      allow delete: if publicOrSameOrg(resource.data) && resource.data.reporterId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if publicOrSameOrg(get(/databases/$(database)/documents/organizationBugs/$(bugId)).data);
        allow create: if signedIn()
          && publicOrSameOrg(get(/databases/$(database)/documents/organizationBugs/$(bugId)).data)
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.bugId == bugId
          && request.resource.data.organizationId == orgId(get(/databases/$(database)/documents/organizationBugs/$(bugId)).data)
          && request.resource.data.organizationName == orgName(get(/databases/$(database)/documents/organizationBugs/$(bugId)).data)
          && request.resource.data.authorName is string
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 500
          && request.resource.data.reaction is string
          && request.resource.data.createdAt is string;
        allow update: if false;
        allow delete: if signedIn()
          && publicOrSameOrg(get(/databases/$(database)/documents/organizationBugs/$(bugId)).data)
          && get(/databases/$(database)/documents/organizationBugs/$(bugId)).data.reporterId == request.auth.uid;
      }
    }

    match /organizations/{organizationId} {
      allow read: if signedIn()
        && userIsOrgMember(organizationId);
      allow create: if signedIn()
        && organizationId != 'public'
        && request.resource.data.keys().hasOnly(['createdAt', 'createdBy', 'createdByName', 'id', 'name'])
        && request.resource.data.id == organizationId
        && request.resource.data.name is string
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdByName is string
        && request.resource.data.createdAt is string;
      allow update, delete: if false;

      match /members/{memberId} {
        allow read: if userIsOrgMember(organizationId) || organizationAdmin(organizationId);
        allow create: if signedIn()
          && memberId == request.resource.data.uid
          && request.resource.data.organizationId == organizationId
          && request.resource.data.organizationName is string
          && request.resource.data.displayName is string
          && request.resource.data.email is string
          && request.resource.data.joinedAt is string
          && request.resource.data.role in ['owner', 'admin', 'member']
          && (
            (
              memberId == request.auth.uid
              && request.resource.data.role == 'owner'
              && getAfter(/databases/$(database)/documents/organizations/$(organizationId)).data.createdBy == request.auth.uid
            )
            || (
              memberId == request.auth.uid
              && request.resource.data.role == 'member'
              && request.resource.data.inviteId is string
              && getAfter(/databases/$(database)/documents/organizationInvites/$(request.resource.data.inviteId)).data.status == 'accepted'
              && getAfter(/databases/$(database)/documents/organizationInvites/$(request.resource.data.inviteId)).data.acceptedById == request.auth.uid
              && getAfter(/databases/$(database)/documents/organizationInvites/$(request.resource.data.inviteId)).data.organizationId == organizationId
            )
            || organizationAdmin(organizationId)
          );
        allow update, delete: if organizationAdmin(organizationId);
      }
    }

    match /organizationInvites/{inviteId} {
      allow read: if signedIn()
        && (organizationAdmin(resource.data.organizationId) || inviteTargetsCurrentUser(resource.data));
      allow create: if validInviteCreate()
        && request.resource.data.id == inviteId;
      allow update: if cancelInvite() || acceptInvite() || declineInvite();
      allow delete: if false;
    }

    match /trades/{tradeId} {
      allow read: if signedIn()
        && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.id == tradeId
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.fromUserName is string
        && request.resource.data.toUserName is string
        && request.resource.data.offerBugId is string
        && request.resource.data.requestBugId is string
        && request.resource.data.offerBugId != request.resource.data.requestBugId
        && request.resource.data.status == 'Open'
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
      allow update: if signedIn()
        && resource.data.status == 'Open'
        && resource.data.toUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.status in ['Geaccepteerd', 'Afgewezen']
        && request.resource.data.updatedAt is string;
      allow delete: if false;
    }

    match /bugSmashDuels/{duelId} {
      allow read: if signedIn() && isDuelParticipant(resource.data);
      allow create: if validDuelCreate(duelId);
      allow update: if acceptOrDeclineDuel()
        || cancelOwnDuel()
        || submitOwnDuelScore()
        || claimOwnDuelReward()
        || acknowledgeDuelResult();
      allow delete: if false;
    }
  }
}
