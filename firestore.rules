rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validStatus(status) {
      return status in ['Nieuw', 'Bevestigd', 'In behandeling', 'Gefixt', 'Afgekeurd', 'Dubbel'];
    }

    function validSeverity(severity) {
      return severity in ['Laag', 'Normaal', 'Hoog', 'Kritiek'];
    }

    function validNotificationType(type) {
      return type in ['trade', 'new_bug', 'comment', 'bug_update', 'bugdex'];
    }

    function validInventoryData(bugId) {
      return request.resource.data.bugId == bugId
        && request.resource.data.count is int
      && request.resource.data.count >= 0
        && request.resource.data.firstUnlockedAt is string
        && request.resource.data.lastUnlockedAt is string
        && request.resource.data.rarity is string
        && request.resource.data.sources is list;
    }

    function acceptedTradeData() {
      return request.resource.data.lastTradeId is string
        && getAfter(/databases/$(database)/documents/trades/$(request.resource.data.lastTradeId)).data.status == 'Geaccepteerd'
        && getAfter(/databases/$(database)/documents/trades/$(request.resource.data.lastTradeId)).data.toUserId == request.auth.uid;
    }

    function tradeGain(userId, bugId) {
      let trade = getAfter(/databases/$(database)/documents/trades/$(request.resource.data.lastTradeId)).data;
      return (userId == trade.fromUserId && bugId == trade.requestBugId)
        || (userId == trade.toUserId && bugId == trade.offerBugId);
    }

    function tradeLoss(userId, bugId) {
      let trade = getAfter(/databases/$(database)/documents/trades/$(request.resource.data.lastTradeId)).data;
      return (userId == trade.fromUserId && bugId == trade.offerBugId)
        || (userId == trade.toUserId && bugId == trade.requestBugId);
    }

    function tradeInventoryCreate(userId, bugId) {
      return signedIn()
        && validInventoryData(bugId)
        && acceptedTradeData()
        && tradeGain(userId, bugId)
        && request.resource.data.count == 1;
    }

    function tradeInventoryUpdate(userId, bugId) {
      return signedIn()
        && validInventoryData(bugId)
        && acceptedTradeData()
        && (
          (tradeGain(userId, bugId) && request.resource.data.count == resource.data.count + 1)
          || (tradeLoss(userId, bugId) && resource.data.count >= 1 && request.resource.data.count == resource.data.count - 1)
        );
    }

    function validUpvotes(data) {
      return data.upvoteUserIds is list
        && data.upvoteCount is int
        && data.upvoteCount == data.upvoteUserIds.size();
    }

    function onlyUpvoteFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvoteUserIds', 'upvoteCount', 'updatedAt']);
    }

    function firstLegacyUpvote() {
      return !resource.data.keys().hasAll(['upvoteUserIds', 'upvoteCount'])
        && validUpvotes(request.resource.data)
        && request.resource.data.upvoteCount == 1
        && request.auth.uid in request.resource.data.upvoteUserIds;
    }

    function toggledOwnUpvote() {
      return validUpvotes(resource.data)
        && validUpvotes(request.resource.data)
        && (
          (!(request.auth.uid in resource.data.upvoteUserIds)
            && request.auth.uid in request.resource.data.upvoteUserIds
            && request.resource.data.upvoteUserIds.size() == resource.data.upvoteUserIds.size() + 1
            && request.resource.data.upvoteUserIds.hasAll(resource.data.upvoteUserIds))
          ||
          (request.auth.uid in resource.data.upvoteUserIds
            && !(request.auth.uid in request.resource.data.upvoteUserIds)
            && resource.data.upvoteUserIds.size() == request.resource.data.upvoteUserIds.size() + 1
            && resource.data.upvoteUserIds.hasAll(request.resource.data.upvoteUserIds))
        );
    }

    function validBugCreate() {
      return request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'Nieuw'
        && validSeverity(request.resource.data.severity)
        && request.resource.data.title is string
        && request.resource.data.project is string
        && request.resource.data.description is string
        && validUpvotes(request.resource.data)
        && request.resource.data.upvoteCount == 0;
    }

    function reporterBugUpdate() {
      return resource.data.reporterId == request.auth.uid
        && request.resource.data.reporterId == resource.data.reporterId
        && validStatus(request.resource.data.status)
        && validSeverity(request.resource.data.severity)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'points', 'updatedAt']);
    }

    function upvoteUpdate() {
      return onlyUpvoteFieldsChanged()
        && resource.data.reporterId != request.auth.uid
        && (firstLegacyUpvote() || toggledOwnUpvote());
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && (!request.resource.data.keys().hasAny(['active']) || request.resource.data.active == true);
      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && (!request.resource.data.keys().hasAny(['active']) || request.resource.data.active == true);
      allow delete: if signedIn() && resource.data.reporterId == request.auth.uid;

      match /bugdex/{bugId} {
        allow read: if signedIn();
        allow create: if (signedIn()
          && request.auth.uid == userId
          && validInventoryData(bugId))
          || tradeInventoryCreate(userId, bugId);
        allow update: if (signedIn()
          && request.auth.uid == userId
          && validInventoryData(bugId))
          || tradeInventoryUpdate(userId, bugId);
        allow delete: if false;
      }

      match /bugdexEvents/{eventId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.id == eventId
          && request.resource.data.source is string
          && request.resource.data.createdAt is string;
        allow update, delete: if false;
      }

      match /settings/{settingId} {
        allow read: if signedIn()
          && request.auth.uid == userId
          && settingId == 'notifications';
        allow create, update: if signedIn()
          && request.auth.uid == userId
          && settingId == 'notifications'
          && request.resource.data.trade is bool
          && request.resource.data.new_bug is bool
          && request.resource.data.comment is bool
          && request.resource.data.bug_update is bool
          && request.resource.data.bugdex is bool;
        allow delete: if false;
      }

      match /notifications/{notificationId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create: if signedIn()
          && request.resource.data.id == notificationId
          && validNotificationType(request.resource.data.type)
          && request.resource.data.title is string
          && request.resource.data.body is string
          && request.resource.data.actorId == request.auth.uid
          && request.resource.data.actorName is string
          && request.resource.data.createdAt is string
          && request.resource.data.read == false;
        allow update: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
          && request.resource.data.read is bool;
        allow delete: if false;
      }
    }

    match /bugs/{bugId} {
      allow read: if signedIn();
      allow create: if signedIn() && validBugCreate();
      allow update: if signedIn() && (reporterBugUpdate() || upvoteUpdate());
      allow delete: if signedIn() && resource.data.reporterId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.bugId == bugId
          && request.resource.data.authorName is string
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 500
          && request.resource.data.reaction is string
          && request.resource.data.createdAt is string;
        allow update: if false;
        allow delete: if signedIn()
          && get(/databases/$(database)/documents/bugs/$(bugId)).data.reporterId == request.auth.uid;
      }
    }

    match /trades/{tradeId} {
      allow read: if signedIn()
        && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.id == tradeId
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.fromUserName is string
        && request.resource.data.toUserName is string
        && request.resource.data.offerBugId is string
        && request.resource.data.requestBugId is string
        && request.resource.data.offerBugId != request.resource.data.requestBugId
        && request.resource.data.status == 'Open'
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
      allow update: if signedIn()
        && resource.data.status == 'Open'
        && resource.data.toUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.status in ['Geaccepteerd', 'Afgewezen']
        && request.resource.data.updatedAt is string;
      allow delete: if false;
    }
  }
}
