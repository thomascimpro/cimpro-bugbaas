  <TextView
    android:id="@+id/radarStatus"
    android:layout_width="match_parent"
    android:layout_height="24dp"
    android:layout_gravity="bottom"
    android:background="@drawable/bug_radar_label_background"
    android:gravity="center"
    android:maxLines="1"
    android:text="SCANNING"
    android:textColor="#B7E7CB"
    android:textSize="11sp"
    android:textStyle="bold" />

  <ImageView
    android:id="@+id/radarRarityAura"
    android:layout_width="132dp"
    android:layout_height="132dp"
    android:layout_gravity="center"
    android:contentDescription="@null"
    android:scaleType="fitCenter"
    android:src="@drawable/bug_radar_aura_epic_art"
    android:visibility="gone" />

  <ImageView
    android:id="@+id/radarBugImage"
    android:layout_width="96dp"
    android:layout_height="78dp"
    android:layout_gravity="center"
    android:contentDescription="@null"
    android:scaleType="fitCenter"
    android:src="@drawable/bugdex_zilvervisje"
    android:visibility="gone" />

  <TextView
    android:id="@+id/radarQueueCount"
    android:layout_width="34dp"
    android:layout_height="24dp"
    android:layout_gravity="top|right"
    android:layout_marginTop="10dp"
    android:layout_marginRight="10dp"
    android:background="@drawable/bug_radar_label_background"
    android:gravity="center"
    android:maxLines="1"
    android:text="x2"
    android:textColor="#FFFFFF"
    android:textSize="11sp"
    android:textStyle="bold"
    android:visibility="gone" />

  <LinearLayout
    android:id="@+id/radarLabel"
    android:layout_width="match_parent"
    android:layout_height="24dp"
    android:layout_gravity="bottom"
    android:background="@drawable/bug_radar_label_background"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingLeft="8dp"
    android:paddingRight="8dp"
    android:visibility="gone">

    <TextView
      android:id="@+id/radarBugName"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:gravity="center"
      android:maxLines="1"
      android:textColor="#FFFFFF"
      android:textSize="12sp"
      android:textStyle="bold" />
