<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widgetRoot"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/bug_radar_widget_background"
  android:gravity="center_vertical"
  android:orientation="horizontal">

  <ImageView
    android:id="@+id/radarIcon"
    android:layout_width="58dp"
    android:layout_height="58dp"
    android:contentDescription="@null"
    android:src="@drawable/ic_bug_radar" />

  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginLeft="10dp"
    android:layout_weight="1"
    android:orientation="vertical">

    <TextView
      android:id="@+id/radarTitle"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textColor="#D7BD57"
      android:textSize="11sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/radarBugName"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="#FFFFFF"
      android:textSize="17sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/radarMeta"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="#B7E7CB"
      android:textSize="12sp" />

    <TextView
      android:id="@+id/radarAction"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="3dp"
      android:textColor="#FFFFFF"
      android:textSize="12sp" />
  </LinearLayout>
</LinearLayout>
